# Zerodha Kite Connect
# Redirect URL to register in your app at https://developers.kite.trade/apps:
#   http://127.0.0.1:8765
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_USER_ID=your_kite_user_id
KITE_ACCESS_TOKEN=your_kite_access_token

# Telegram Alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Claude API (Phase 2 - news sentiment)
ANTHROPIC_API_KEY=your_claude_api_key

# Trading Mode: paper | live
TRADING_MODE=paper

# Notion Integration (trade journal + pre-market pulse)
NOTION_API_KEY=your_notion_api_key
NOTION_TRADES_DB_ID=your_notion_trades_db_id
